# LetsBuild Environment Variables
# Copy to .env and fill in your values.
# NEVER commit the .env file — it's in .gitignore.

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here
GITHUB_TOKEN=ghp_your-token-here

# Optional — for Company Intelligence (Layer 2)
SERPAPI_KEY=your-serpapi-key-here

# Optional — for notifications
LETSBUILD_TELEGRAM_BOT_TOKEN=
LETSBUILD_SLACK_WEBHOOK=
LETSBUILD_DISCORD_WEBHOOK=

# Optional — for local model fallbacks
VLLM_ENDPOINT=http://localhost:8000/v1
